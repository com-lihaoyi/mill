[
  {
    "includes": [
      "glob:build.mill"
    ],
    "steps": [
      {
        "$type": "ScalaFmt"
      }
    ]
  },
  {
    "includes": [
      "glob:**.java"
    ],
    "steps": [
      {
        "$type": "GoogleJavaFormat",
        "version": "1.35.0"
      },
      {
        "$type": "LicenseHeader",
        "delimiter": "(package|import|public|class|module) "
      }
    ]
  },
  {
    "includes": [
      "glob:**.{kt,kts}"
    ],
    "steps": [
      {
        "$type": "Ktfmt"
      },
      {
        "$type": "LicenseHeader",
        "delimiter": "(package |@file|import )"
      }
    ]
  }
]